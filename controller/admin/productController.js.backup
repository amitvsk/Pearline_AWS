// Get All Products
export const getProducts = async (req, res) => {
  try {
    const products = await productModel.find().sort({ createdAt: -1 }).populate("collection", "title");
    
    // Convert relative URLs to full URLs
    const processedProducts = products.map(product => {
      const productObj = product.toObject();
      
      if (productObj.image) productObj.image = toFullUrl(productObj.image);
      if (productObj.images) pmg));
      
      if (productObj.variants) {
        productObj.variants = productObj.variants.map(v => ({
          ...v,
          image: toFullUrl(v.image),
          images: v.images ? v.images.map(img => toFullUrl(img)) : []
        }));
      }
      
      return productObj;
    });
    
